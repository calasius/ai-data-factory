# Generation runs through opencode + DeepSeek. Set DEEPSEEK_API_KEY below.
# The opencode binary must be on PATH (or at ~/.opencode/bin) in the runtime.

POSTGRES_USER=synth
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=synthdata
DATABASE_URL=postgresql+asyncpg://synth:changeme_strong_password@postgres:5432/synthdata

REDIS_URL=redis://redis:6379/0

SECRET_KEY=changeme_random_32_chars_min
PROJECTS_DIR=/data/projects
TEMPLATES_DIR=/app/tools/templates
COMMANDS_DIR=/app/.claude/commands
MAX_CONCURRENT_PIPELINES=3

# opencode + DeepSeek engine
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_AUTHORING_MODEL=deepseek-v4-flash
DEEPSEEK_EDIT_MODEL=deepseek-chat
OPENCODE_CONFIG_PATH=/app/api/opencode.json

NEXT_PUBLIC_API_URL=http://localhost:8000
